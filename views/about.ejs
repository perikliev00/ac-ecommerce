              <li><strong><%= copy.offerMaintenance || 'Профилактика и сервиз' %></strong> – <%= copy.offerMaintenanceText || '' %></li>
              <li><strong><%= copy.offerRepair || 'Ремонт на климатици' %></strong> – <%= copy.offerRepairText || '' %></li>
