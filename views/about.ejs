            <span class="about-stat__label"><%= copy.areas || 'Несебър, Слънчев бряг, Равда, Свети Влас' %></span>
          </div>
        </div>
      </div>
    </section>

    <section class="about-content" aria-label="<%= copy.heroLabel || 'За нас' %>">
      <div class="container">
        <div class="about-content__grid">
          <article class="about-block">
            <h2 class="about-block__title"><%= copy.whoTitle || 'Кой сме ние' %></h2>
            <p class="about-block__text">
              <%= copy.whoText1 || '' %>
