<%
  const lp = typeof localizePath === 'function' ? localizePath : function(path) { return path; };
  const locale = typeof currentLocale !== 'undefined' && currentLocale ? currentLocale : 'bg';
  const langLinks = typeof languageLinks !== 'undefined' && Array.isArray(languageLinks) ? languageLinks : [];

  const nav = locale === 'en'
    ? { products: 'Air Conditioners', services: 'Services', blog: 'Blog', about: 'About', contact: 'Contact',
        inverter: 'Inverter', hyperinverter: 'Hyper Inverter', floor: 'Floor Standing',
        all: 'All products', lang: 'Language', call: 'Call us', whatsapp: 'WhatsApp',
        menu: 'Menu', close: 'Close menu', nav: 'Navigation', categories: 'Categories' }
    : locale === 'de'
      ? { products: 'Klimaanlagen', services: 'Leistungen', blog: 'Blog', about: 'Über uns', contact: 'Kontakt',
          inverter: 'Inverter', hyperinverter: 'Hyper-Inverter', floor: 'Standgeräte',
          all: 'Alle Produkte', lang: 'Sprache', call: 'Anrufen', whatsapp: 'WhatsApp',
          menu: 'Menü', close: 'Menü schließen', nav: 'Navigation', categories: 'Kategorien' }
      : locale === 'ru'
        ? { products: 'Кондиционеры', services: 'Услуги', blog: 'Блог', about: 'О нас', contact: 'Контакты',
            inverter: 'Инверторные', hyperinverter: 'Гиперинверторные', floor: 'Напольные',
            all: 'Все продукты', lang: 'Язык', call: 'Позвонить', whatsapp: 'WhatsApp',
            menu: 'Меню', close: 'Закрыть меню', nav: 'Навигация', categories: 'Категории' }
        : { products: 'Климатици', services: 'Услуги', blog: 'Блог', about: 'За нас', contact: 'Контакти',
            inverter: 'Инверторни', hyperinverter: 'Хиперинверторни', floor: 'Подови',
            all: 'Всички продукти', lang: 'Език', call: 'Обади се', whatsapp: 'WhatsApp',
            menu: 'Меню', close: 'Затвори меню', nav: 'Навигация', categories: 'Категории' };

  const flagByLang = function(lang) {
    const v = String(lang || '').toLowerCase();
    if (v.startsWith('bg')) return '🇧🇬';
    if (v.startsWith('en')) return '🇬🇧';
    if (v.startsWith('de')) return '🇩🇪';
    if (v.startsWith('ru')) return '🇷🇺';
    return '🌐';
  };
%>
<div class="m-overlay" id="overlay" hidden></div>
<aside class="m-drawer" id="drawer" aria-label="<%= nav.menu %>" aria-hidden="true">

  <!-- Header bar -->
  <div class="m-drawer__bar">
    <span class="m-drawer__title"><%= nav.menu %></span>
    <button class="m-drawer__close icon-btn" id="btnCloseMenu" aria-label="<%= nav.close %>">
      <svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
        <path d="M18.3 5.7 12 12l6.3 6.3-1.4 1.4L10.6 13.4 4.3 19.7 2.9 18.3 9.2 12 2.9 5.7 4.3 4.3l6.3 6.3 6.3-6.3Z" />
      </svg>
    </button>
  </div>

  <!-- Scrollable body -->
  <div class="m-drawer__body">

    <!-- Navigation -->
    <nav class="m-drawer__nav" aria-label="<%= nav.nav %>">

      <!-- Климатици expandable -->
      <details class="m-drawer__details">
        <summary class="m-drawer__link m-drawer__link--summary">
          <span><%= nav.products %></span>
          <span class="m-drawer__chev" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </span>
        </summary>
        <div class="m-drawer__sub" aria-label="<%= nav.categories %>">
          <a class="m-drawer__sublink" href="<%= lp('/produkti') %>"><%= nav.all %></a>
          <a class="m-drawer__sublink" href="<%= lp('/inverter') %>"><%= nav.inverter %></a>
          <a class="m-drawer__sublink" href="<%= lp('/hyperinverter') %>"><%= nav.hyperinverter %></a>
          <a class="m-drawer__sublink" href="<%= lp('/floor') %>"><%= nav.floor %></a>
        </div>
      </details>

      <a class="m-drawer__link" href="<%= lp('/uslugi') %>"><%= nav.services %></a>
      <a class="m-drawer__link" href="<%= lp('/blog') %>"><%= nav.blog %></a>
      <a class="m-drawer__link" href="<%= lp('/about') %>"><%= nav.about %></a>
      <a class="m-drawer__link" href="<%= lp('/kontakti') %>"><%= nav.contact %></a>
    </nav>

    <!-- Language switcher -->
    <% if (langLinks.length > 0) { %>
    <div class="m-drawer__langs" aria-label="<%= nav.lang %>">
      <p class="m-drawer__section-label"><%= nav.lang %></p>
      <div class="m-drawer__lang-grid">
        <% langLinks.forEach(function(link) { %>
          <a class="m-drawer__lang<%= link.current ? ' is-current' : '' %>" href="<%= link.href %>" hreflang="<%= link.htmlLang %>">
            <span class="m-drawer__flag" aria-hidden="true"><%= flagByLang(link.htmlLang) %></span>
            <span class="m-drawer__lang-label"><%= link.nativeLabel %></span>
          </a>
        <% }); %>
      </div>
    </div>
    <% } %>

    <!-- Contact: phone -->
    <a class="m-drawer__contact" href="tel:+359898123123">
      <span class="m-drawer__contact-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
          <path d="M6.6 10.8c1.6 3.2 3.4 5 6.6 6.6l2.2-2.2c.3-.3.8-.4 1.2-.2 1.3.5 2.7.8 4.1.8.7 0 1.3.6 1.3 1.3V21c0 .7-.6 1.3-1.3 1.3C10.2 22.3 1.7 13.8 1.7 3.3 1.7 2.6 2.3 2 3 2h3.8c.7 0 1.3.6 1.3 1.3 0 1.4.3 2.8.8 4.1.1.4 0 .9-.3 1.2l-2 2.2Z"/>
        </svg>
      </span>
      <span class="m-drawer__contact-body">
        <span class="m-drawer__contact-label"><%= nav.call %></span>
        <span class="m-drawer__contact-number">+359 898 123 123</span>
      </span>
    </a>

    <!-- Contact: WhatsApp -->
    <a class="m-drawer__contact m-drawer__contact--wa" href="https://wa.me/359898123123" target="_blank" rel="noopener noreferrer">
      <span class="m-drawer__contact-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </span>
      <span class="m-drawer__contact-body">
        <span class="m-drawer__contact-label"><%= nav.whatsapp %></span>
        <span class="m-drawer__contact-number">089 812 3123</span>
      </span>
    </a>

  </div><!-- /body -->
</aside>
<%- include('cart-drawer') %>
