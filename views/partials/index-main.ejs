    <% } else { %>
    <div class="reviews__slider" id="reviewsSlider" role="region" aria-roledescription="carousel">
      <button type="button" class="reviews__arrow reviews__arrow--prev" id="reviewsPrev" aria-label="<%= copy.reviewsPrev || 'Предишна страница' %>">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button type="button" class="reviews__arrow reviews__arrow--next" id="reviewsNext" aria-label="<%= copy.reviewsNext || 'Следваща страница' %>">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </button>
      <div class="reviews__viewport" id="reviewsViewport">
        <div class="reviews__track" id="reviewsTrack">
          <% reviewsList.forEach(function(rev, i) { %>
          <div class="reviews__slide" style="flex: 0 0 <%= 100 / reviewsList.length %>%; width: <%= 100 / reviewsList.length %>%;">
            <article class="reviews__card">
              <h3 class="reviews__name"><%= rev.name %></h3>
              <div class="reviews__stars" aria-label="<%= copy.reviewsRating || 'Рейтинг' %> <%= rev.rating %> <%= copy.reviewsOutOfFive || 'от 5' %>">
                <% for (var s = 0; s < 5; s++) { %><span class="reviews__star" aria-hidden="true"><%= s < (rev.rating || 5) ? '★' : '☆' %></span><% } %>
              </div>
              <p class="reviews__text"><%= rev.text %></p>
            </article>
          </div>
          <% }); %>
        </div>
      </div>
      <div class="reviews__pagination" role="tablist" aria-label="<%= copy.reviewsPages || 'Страници отзиви' %>">
        <% var desktopPageCount = Math.ceil(reviewsList.length / 3); %>
        <% reviewsList.forEach(function(_, i) { %>
        <button type="button" class="reviews__dot <%= i === 0 ? 'is-active' : '' %> <%= i >= desktopPageCount ? 'reviews__dot--mobile' : '' %>" data-index="<%= i %>" aria-label="<%= copy.blogPage || 'Страница ' %><%= i + 1 %>" aria-selected="<%= i === 0 ? 'true' : 'false' %>"></button>
        <% }); %>
      </div>
    </div>
    <% } %>
  </div>
</section>
