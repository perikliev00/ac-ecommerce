<script>
  (function () {
    function cardsPerPage() {
      if (window.innerWidth <= 760) return 1;
      if (window.innerWidth <= 1080) return 2;
      return 3;
    }

    var slider = document.getElementById('homeBlogSlider');
    var viewport = document.getElementById('homeBlogViewport');
    var track = document.getElementById('homeBlogGrid');
    var pagination = document.getElementById('homeBlogPagination');
    var prevBtn = document.getElementById('homeBlogPrev');
    var nextBtn = document.getElementById('homeBlogNext');
    if (!slider || !viewport || !track || !pagination) return;

    var slides = Array.prototype.slice.call(track.querySelectorAll('[data-home-blog-card]'));
    var currentPage = 0;

    function renderPagination(totalPages) {
      pagination.innerHTML = '';
      if (totalPages <= 1) return;

      for (var i = 0; i < totalPages; i++) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'reviews__dot' + (i === currentPage ? ' is-active' : '');
        btn.setAttribute('data-index', String(i));
        btn.setAttribute('aria-label', '<%= copy.blogPage || 'Страница ' %>' + (i + 1));
        btn.setAttribute('aria-selected', i === currentPage ? 'true' : 'false');
        btn.addEventListener('click', function () {
          currentPage = Number(this.getAttribute('data-index') || 0);
          update();
        });
        pagination.appendChild(btn);
      }
    }

    function update() {
      var perPage = cardsPerPage();
      var totalPages = Math.max(1, Math.ceil(slides.length / perPage));
      if (currentPage >= totalPages) currentPage = 0;

      track.style.width = (totalPages * 100) + '%';

      var slideWidth = 100 / (slides.length || 1);
      slides.forEach(function (slide) {
        slide.style.flex = '0 0 ' + slideWidth + '%';
        slide.style.width = slideWidth + '%';
      });

      track.style.transform = 'translateX(-' + (currentPage * (100 / totalPages)) + '%)';
      renderPagination(totalPages);

      if (prevBtn) prevBtn.hidden = totalPages <= 1;
      if (nextBtn) nextBtn.hidden = totalPages <= 1;
    }

    prevBtn && prevBtn.addEventListener('click', function () {
      var perPage = cardsPerPage();
      var totalPages = Math.max(1, Math.ceil(slides.length / perPage));
      currentPage = (currentPage - 1 + totalPages) % totalPages;
      update();
    });

    nextBtn && nextBtn.addEventListener('click', function () {
      var perPage = cardsPerPage();
      var totalPages = Math.max(1, Math.ceil(slides.length / perPage));
      currentPage = (currentPage + 1) % totalPages;
      update();
    });

    var resizeTimer;
    window.addEventListener('resize', function () {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(update, 120);
    });

    update();
  })();
</script>
<% } %>

