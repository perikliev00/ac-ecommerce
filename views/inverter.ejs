<!DOCTYPE html>
<%
  const locale = typeof currentLocale !== 'undefined' && currentLocale ? currentLocale : 'bg';
  const title = locale === 'en' ? 'Inverter air conditioners' : locale === 'de' ? 'Inverter-Klimaanlagen' : locale === 'ru' ? 'Инверторные кондиционеры' : 'Инверторни климатици';
%>
<html lang="<%= typeof htmlLang !== 'undefined' && htmlLang ? htmlLang : 'bg' %>">
<head>
  <%- include('partials/head', { extraStyles: ['inverter.css'] }) %>
</head>
<body>
  <%- include('partials/loader') %>
  <%- include('partials/header') %>
  <%- include('partials/drawer') %>

  <main class="page" role="main">
    <%- include('partials/catalog', { catalogTitle: title, breadcrumbCurrent: title }) %>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
